{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "eattendance-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-06",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "DEV_MODE": "false"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "eattendance-db",
      "database_id": "__D1_DATABASE_ID__"
    }
  ]
}

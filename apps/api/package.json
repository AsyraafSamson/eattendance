{
  "name": "api",
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-wrangler-config.mjs",
    "dev": "wrangler dev --local",
    "predeploy": "node scripts/generate-wrangler-config.mjs",
    "deploy": "wrangler deploy --minify",
    "precf-typegen": "node scripts/generate-wrangler-config.mjs",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.10",
    "jsonwebtoken": "^9.0.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/qrcode": "^1.5.6",
    "vitest": "^2.1.9",
    "wrangler": "^4.4.0"
  }
}
